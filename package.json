{
  "name": "docula-monorepo",
  "version": "2.0.0",
  "description": "Beautiful Website for Your Projects — monorepo",
  "type": "module",
  "private": true,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jaredwray/docula.git"
  },
  "author": "Jared Wray <me@jaredwray.com>",
  "license": "MIT",
  "engines": {
    "node": "^22.18.0 || >=24.0.0"
  },
  "scripts": {
    "clean": "pnpm -r --if-present clean && rimraf ./node_modules ./coverage ./site/dist",
    "build": "pnpm -r build",
    "build:binary": "pnpm --filter docula build:binary",
    "lint": "biome check --write --error-on-warnings",
    "lint:ci": "biome check --error-on-warnings",
    "test": "pnpm lint && pnpm -r test:unit",
    "test:ci": "pnpm lint:ci && pnpm -r test:unit",
    "test:e2e": "pnpm --filter docula test:e2e",
    "website:build": "node packages/docula/bin/docula.js build -s ./site -o ./site/dist",
    "website:dev": "pnpm --filter docula build && node packages/docula/bin/docula.js dev -s ./site -p 3333"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "docula": "workspace:*",
    "dotenv": "^17.4.2",
    "rimraf": "^6.1.3",
    "typescript": "^6.0.3"
  },
  "packageManager": "pnpm@11.1.3+sha512.c85357fe17ca12dd23dd7071822666dfd7e3cb76fe214e3370b5ea2fb34f2a231185509b63e717f3cd0acb38dd3f8d82bcd5e8172400ae678b70ea4fbed0896d"
}
